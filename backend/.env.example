# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=language_tool
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
JWT_EXPIRE=7d

# Admin Initialization
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password

# Super-admin bootstrap (REQUIRED to auto-create the super admin; no insecure default).
# Must differ from ADMIN_EMAIL. If unset, super-admin bootstrap is skipped.
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=your_strong_super_admin_password

# Security
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Google Cloud API key — reused for paid Translation + Text-to-Speech.
# Enable "Cloud Translation API" and "Cloud Text-to-Speech API" on the project, then create an API key.
# Only schools the super admin marks premium use the paid path; everyone else uses the free engine.
GOOGLE_API_KEY=
# Legacy alias (still honored if GOOGLE_API_KEY is unset)
GOOGLE_TRANSLATE_API_KEY=

# Email / SMTP (required for forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
APP_NAME=Spoken Edge

# Stripe Recurring Billing
# Use test keys (sk_test_… / pk_test_…) in development.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From `stripe listen` (CLI) locally, or the Dashboard webhook endpoint in production.
STRIPE_WEBHOOK_SECRET=whsec_xxx